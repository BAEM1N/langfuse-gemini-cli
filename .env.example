# Langfuse credentials for langfuse-gemini-cli
# Copy this file to ~/.gemini/.env and fill in your values.
# Environment variables and settings.json env take priority over .env values.

TRACE_TO_LANGFUSE=true
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_USER_ID=gemini-user

# Optional
# GC_LANGFUSE_DEBUG=true
# GC_LANGFUSE_MAX_CHARS=20000
# GC_LANGFUSE_HOSTNAME=my-machine
